# ============================================================
# Kosovo Invoice Automation — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# n8n Encryption Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
N8N_ENCRYPTION_KEY=GENERATE_A_RANDOM_32_CHAR_HEX_KEY

# n8n Admin Credentials
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHOOSE_A_STRONG_PASSWORD

# Unstract API Key (find in Unstract → API Deployments → Google Prompt API → API Key)
UNSTRACT_API_KEY=YOUR_UNSTRACT_GOOGLE_PROMPT_API_KEY

# ============================================================
# PATHS — Update these to match your machine
# ============================================================

# Where your invoice PDFs/JPGs are stored (Dropbox or local)
INVOICES_PATH=C:/Users/YOUR_USERNAME/Dropbox/Test/Invoices

# Where your bank statements are stored
BANK_STATEMENTS_PATH=C:/Users/YOUR_USERNAME/Dropbox/Test/BankStatements

# Where your Python scripts are stored (this repo's scripts/ folder)
SCRIPTS_PATH=C:/invoice-automation/scripts

# ============================================================
# UNSTRACT — Update the org slug if different
# ============================================================
UNSTRACT_ORG=mock_org
UNSTRACT_API_NAME=google_prompt
